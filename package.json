{
  "name": "emodal-workspace",
  "private": true,
  "version": "2.0.0",
  "description": "eModal v2 workspace: Bootstrap 5 modal helpers, framework adapters, and demo.",
  "author": "Samuel Ribeiro Pinto",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm --workspace apps/demo run dev",
    "test": "npm --workspace packages/emodal run test",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "demo:build": "npm --workspace apps/demo run build",
    "preview": "npm --workspace apps/demo run preview"
  },
  "engines": {
    "node": ">=20"
  }
}
